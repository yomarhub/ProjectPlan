<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ProjectPlan.App"
             xmlns:local="using:ProjectPlan"
             RequestedThemeVariant="Light">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="Assets/Icons/tray.ico" ToolTipText="Mon application" Clicked="Toggle">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Ouvrir" Click="OpenApp" />
                        <NativeMenuItem Header="Quitter" Click="ExitApp" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
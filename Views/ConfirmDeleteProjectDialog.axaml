<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ProjectPlan.Views.ConfirmDeleteProjectDialog"
        Width="540"
        Height="240"
        CanResize="False"
        Background="#EEF0F2"
        Title="Confirmation">

  <Border Padding="16">
    <DockPanel LastChildFill="True">
      <DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" LastChildFill="False">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Button Click="Cancel_Click">Annuler</Button>
          <Button Click="Delete_Click">Supprimer</Button>
        </StackPanel>
      </DockPanel>

      <StackPanel Spacing="10">
        <TextBlock FontSize="20" FontWeight="Bold" Text="Supprimer le projet" />
        <TextBlock x:Name="MessageText"
                   TextWrapping="Wrap"
                   FontSize="14" />
      </StackPanel>
    </DockPanel>
  </Border>
</Window>

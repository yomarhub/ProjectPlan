<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ProjectPlan.ViewModels"
        x:Class="ProjectPlan.Views.ConfirmDeleteProjectDialog"
        x:DataType="vm:ConfirmDeleteProjectDialogViewModel"
        Width="540"
        Height="240"
        CanResize="False"
        Background="{DynamicResource AppBackgroundBrush}"
        Title="Confirmation">

    <Border Padding="16">
        <DockPanel LastChildFill="True">
            <DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding CancelCommand}">Annuler</Button>
                    <Button Classes="destructive" Command="{Binding DeleteCommand}">Supprimer</Button>
                </StackPanel>
            </DockPanel>

            <StackPanel Spacing="10">
                <TextBlock FontSize="20" FontWeight="Bold" Text="Supprimer le projet" />
                <TextBlock Text="{Binding Message}"
                           TextWrapping="Wrap"
                           FontSize="14" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ProjectPlan"
             xmlns:m="using:ProjectPlan.Models"
             xmlns:vm="using:ProjectPlan.ViewModels"
             x:Class="ProjectPlan.Views.ProjectView"
             x:DataType="vm:ProjectViewModel">
  <UserControl.DataTemplates>
    <DataTemplate x:DataType="m:Column">
      <local:ColumnView />
    </DataTemplate>
  </UserControl.DataTemplates>

  <Border Padding="16">
    <StackPanel Spacing="10">
      <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Title}" />
      <TextBlock FontWeight="Bold" Text="{Binding ProjectName}" />
      <TextBlock Text="{Binding Hint}" />
      <TextBlock Text="{Binding ColumnWidth}" />
      <TextBox Watermark="Nom du projet" />
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Columns}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>
      </ScrollViewer>
    </StackPanel>
  </Border>
</UserControl>


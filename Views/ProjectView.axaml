<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ProjectPlan.ViewModels"
             xmlns:infra="using:ProjectPlan.Infrastructure"
             x:Class="ProjectPlan.Views.ProjectView"
             x:DataType="vm:ProjectViewModel">
  <UserControl.Resources>
    <infra:HasPreviousColumnConverter x:Key="HasPreviousColumnConverter" />
    <infra:HasNextColumnConverter x:Key="HasNextColumnConverter" />

    <ControlTheme x:Key="DashboardLikeButtonTheme" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}"
            RenderTransformOrigin="0.5,0.5">
            <Border.Transitions>
              <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
              </Transitions>
            </Border.Transitions>
            <ContentPresenter
              Content="{TemplateBinding Content}"
              ContentTemplate="{TemplateBinding ContentTemplate}"
              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
              Padding="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>

      <Style Selector="^:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource AppAccentTintBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
      </Style>
    </ControlTheme>

    <ControlTheme x:Key="TicketButtonTheme" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}">
            <Border.Transitions>
              <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
              </Transitions>
            </Border.Transitions>
            <ContentPresenter
              Content="{TemplateBinding Content}"
              ContentTemplate="{TemplateBinding ContentTemplate}"
              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
              Padding="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>

      <Style Selector="^:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource AppAccentTintBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
      </Style>
    </ControlTheme>
  </UserControl.Resources>

  <UserControl.DataTemplates>
    <DataTemplate x:DataType="vm:BoardCardViewModel">
      <Grid Margin="0,0,0,8" ColumnDefinitions="*,Auto" ColumnSpacing="6" HorizontalAlignment="Stretch">
        <Button Grid.Column="0"
                Padding="10"
                Theme="{StaticResource TicketButtonTheme}"
                HorizontalAlignment="Stretch"
                x:CompileBindings="False"
                Command="{Binding DataContext.CardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}">
          <StackPanel Spacing="4">
            <TextBlock FontWeight="Bold" Text="{Binding Title}" />
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
          </StackPanel>
        </Button>

        <StackPanel Grid.Column="1" Width="30" Spacing="6" VerticalAlignment="Center">
          <Button Width="30"
                  Height="30"
                  Padding="0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Theme="{StaticResource TicketButtonTheme}"
                  Content="←"
                  x:CompileBindings="False"
                  Command="{Binding DataContext.MoveCardLeftCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  CommandParameter="{Binding}">
            <Button.IsVisible>
              <MultiBinding Converter="{StaticResource HasPreviousColumnConverter}">
                <Binding Path="DataContext.Columns" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                <Binding Path="DataContext.Columns.Count" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                <Binding Path="ColumnId" />
              </MultiBinding>
            </Button.IsVisible>
          </Button>

          <Button Width="30"
                  Height="30"
                  Padding="0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Theme="{StaticResource TicketButtonTheme}"
                  Content="→"
                  x:CompileBindings="False"
                  Command="{Binding DataContext.MoveCardRightCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  CommandParameter="{Binding}">
            <Button.IsVisible>
              <MultiBinding Converter="{StaticResource HasNextColumnConverter}">
                <Binding Path="DataContext.Columns" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                <Binding Path="DataContext.Columns.Count" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                <Binding Path="ColumnId" />
              </MultiBinding>
            </Button.IsVisible>
          </Button>
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate x:DataType="vm:BoardColumnViewModel">
      <Border Width="280" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,12,0">
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Top" Spacing="8">
            <DockPanel LastChildFill="False">
              <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="Bold" Text="{Binding Name}" />
              <Button DockPanel.Dock="Right"
                      Width="30"
                      Height="30"
                      Padding="0"
                      x:CompileBindings="False"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Content="✕"
                      Classes="destructive"
                      Command="{Binding DataContext.DeleteColumnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}" />
            </DockPanel>
          </StackPanel>

          <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,10">
            <Grid RowDefinitions="Auto,Auto" HorizontalAlignment="Stretch">
              <ItemsControl Grid.Row="0" ItemsSource="{Binding Cards}" HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>

              <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="6" HorizontalAlignment="Stretch">
                <Button Grid.Column="0"
                        MinHeight="40"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Stretch"
                        Padding="10,8"
                        HorizontalContentAlignment="Center"
                        Theme="{StaticResource DashboardLikeButtonTheme}"
                        Background="{DynamicResource AppSurfaceAltBrush}"
                        Content="+ Ajouter un ticket"
                        x:CompileBindings="False"
                        Command="{Binding DataContext.AddCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}" />

                <Border Grid.Column="1" Width="30" />
              </Grid>
            </Grid>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Border Padding="16">
    <DockPanel LastChildFill="True">
      <Border DockPanel.Dock="Top" CornerRadius="10" ClipToBounds="True" Padding="16" MinHeight="140">
        <Border.Background>
          <ImageBrush Source="{Binding ProjectImage}" Stretch="UniformToFill" />
        </Border.Background>

        <StackPanel Spacing="8">
          <DockPanel LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" FontSize="22" FontWeight="Bold" Text="{Binding ProjectName}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasProject}">
              <Button Content="Modifier" Command="{Binding EditProjectCommand}" />
              <Button Classes="destructive" Content="Supprimer" Command="{Binding DeleteProjectCommand}" />
            </StackPanel>
          </DockPanel>
          <TextBlock Text="{Binding ProjectDescription}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,14,0,0">
        <StackPanel Orientation="Horizontal">
          <ItemsControl ItemsSource="{Binding Columns}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>

          <Button Width="280"
                  Margin="0,0,12,0"
                  Padding="12"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Theme="{StaticResource DashboardLikeButtonTheme}"
                  Content="+ Ajouter une colonne"
                  Command="{Binding AddColumnCommand}" />
        </StackPanel>
      </ScrollViewer>
    </DockPanel>
  </Border>
</UserControl>

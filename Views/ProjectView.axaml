<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ProjectPlan.ViewModels"
             x:Class="ProjectPlan.Views.ProjectView"
             x:DataType="vm:ProjectViewModel">
  <UserControl.Resources>
    <ControlTheme x:Key="DashboardLikeButtonTheme" TargetType="Button">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
            Background="{TemplateBinding Background}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}"
            RenderTransformOrigin="0.5,0.5">
            <Border.Transitions>
              <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
              </Transitions>
            </Border.Transitions>
            <ContentPresenter
              Content="{TemplateBinding Content}"
              ContentTemplate="{TemplateBinding ContentTemplate}"
              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
              Padding="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>

      <Style Selector="^:pointerover /template/ Border">
        <Setter Property="Background" Value="#DBDBDB" />
      </Style>
    </ControlTheme>

    <ControlTheme x:Key="TicketButtonTheme" TargetType="Button">
      <Setter Property="Background" Value="#EEF0F2" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
            Background="{TemplateBinding Background}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="{TemplateBinding CornerRadius}">
            <Border.Transitions>
              <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
              </Transitions>
            </Border.Transitions>
            <ContentPresenter
              Content="{TemplateBinding Content}"
              ContentTemplate="{TemplateBinding ContentTemplate}"
              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
              Padding="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>

      <Style Selector="^:pointerover /template/ Border">
        <Setter Property="Background" Value="#DBDBDB" />
      </Style>
    </ControlTheme>
  </UserControl.Resources>

  <UserControl.DataTemplates>
    <DataTemplate x:DataType="vm:BoardCardViewModel">
      <Button Margin="0,0,0,8"
              Padding="10"
              Theme="{StaticResource TicketButtonTheme}"
              x:CompileBindings="False"
              Command="{Binding DataContext.CardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
              CommandParameter="{Binding}">
        <StackPanel Spacing="4">
          <TextBlock FontWeight="Bold" Text="{Binding Title}" />
          <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
        </StackPanel>
      </Button>
    </DataTemplate>

    <DataTemplate x:DataType="vm:BoardColumnViewModel">
      <Border Width="280" Background="#FFFFFF" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,12,0">
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Top" Spacing="8">
            <DockPanel LastChildFill="False">
              <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="Bold" Text="{Binding Name}" />
              <Button DockPanel.Dock="Right"
                      Width="30"
                      Height="30"
                      Padding="0"
                      x:CompileBindings="False"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Content="✕"
                      Command="{Binding DataContext.DeleteColumnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}" />
            </DockPanel>
                <Button MinHeight="40"
                    HorizontalAlignment="Stretch"
                  Padding="10,8"
                    HorizontalContentAlignment="Center"
                    Theme="{StaticResource DashboardLikeButtonTheme}"
                    Content="+ Ajouter un ticket"
                    x:CompileBindings="False"
                    Command="{Binding DataContext.AddCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}" />
          </StackPanel>

          <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,10">
            <ItemsControl ItemsSource="{Binding Cards}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Border Padding="16">
    <DockPanel LastChildFill="True">
      <StackPanel DockPanel.Dock="Top" Spacing="8">
        <DockPanel LastChildFill="False">
          <TextBlock DockPanel.Dock="Left" FontSize="22" FontWeight="Bold" Text="{Binding ProjectName}" />
          <Button DockPanel.Dock="Right"
                  IsVisible="{Binding HasProject}"
                  Content="Supprimer"
              Command="{Binding DeleteProjectCommand}" />
        </DockPanel>
        <TextBlock Text="{Binding ProjectDescription}" TextWrapping="Wrap" />
      </StackPanel>

      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,14,0,0">
        <StackPanel Orientation="Horizontal">
          <ItemsControl ItemsSource="{Binding Columns}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>

          <Button Width="280"
                  Margin="0,0,12,0"
                  Padding="12"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Theme="{StaticResource DashboardLikeButtonTheme}"
                  Content="+ Ajouter une colonne"
                  Command="{Binding AddColumnCommand}" />
        </StackPanel>
      </ScrollViewer>
    </DockPanel>
  </Border>
</UserControl>

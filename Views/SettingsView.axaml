<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ProjectPlan.ViewModels"
             x:Class="ProjectPlan.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <Border Padding="16">
    <StackPanel Spacing="10">
      <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Title}" />
      <TextBlock Text="Page de paramètres (à compléter)." />
    </StackPanel>
  </Border>
</UserControl>

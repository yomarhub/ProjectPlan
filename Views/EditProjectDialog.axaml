<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ProjectPlan.ViewModels"
        x:Class="ProjectPlan.Views.EditProjectDialog"
        x:DataType="vm:EditProjectDialogViewModel"
        Width="520"
        Height="520"
        CanResize="False"
        Background="#EEF0F2"
        Title="Modifier un projet">

  <Border Padding="16">
    <DockPanel LastChildFill="True">
      <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0" LastChildFill="False">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Button Command="{Binding CancelCommand}">Annuler</Button>
          <Button Command="{Binding SaveCommand}">Enregistrer</Button>
        </StackPanel>
      </DockPanel>

      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12">
          <TextBlock FontSize="20" FontWeight="Bold" Text="Modifier un projet" />

          <StackPanel Spacing="6">
            <TextBlock Text="Titre" />
            <TextBox Text="{Binding ProjectTitle}" Watermark="Ex: Mon projet" />
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="Description" />
            <TextBox Text="{Binding ProjectDescription}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="110"
                     Watermark="Décris rapidement le projet..." />
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="Image" />
            <DockPanel LastChildFill="True">
              <Button DockPanel.Dock="Left" Width="150" Command="{Binding ChooseImageCommand}">Choisir...</Button>
              <TextBlock Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis"
                         Text="{Binding ImagePath}" />
            </DockPanel>

            <Border Background="#FFFFFF" BorderThickness="1" CornerRadius="8" Padding="8">
              <Image Height="160" Source="{Binding ImagePreview}" Stretch="Uniform" />
            </Border>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </DockPanel>
  </Border>
</Window>
